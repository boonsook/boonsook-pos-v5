# ═══════════════════════════════════════════════════════════
# Cloudflare Pages — HTTP cache headers
# ═══════════════════════════════════════════════════════════

# index.html: ห้าม cache (ต้องโหลดใหม่ทุกครั้งเพื่อเช็ค ?v= ของ main.js)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate

# Service Worker: ห้าม cache (browser ต้องเช็คอัปเดตทุกครั้ง)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# manifest.json: revalidate
/manifest.json
  Cache-Control: no-cache, must-revalidate

# main.js: cache ได้นานเพราะใช้ ?v= cache busting
/main.js
  Cache-Control: public, max-age=31536000, immutable

# style.css: cache ได้นานเพราะใช้ ?v= cache busting
/style.css
  Cache-Control: public, max-age=31536000, immutable

# JS modules ใน /modules/: must-revalidate (เพราะ import path ไม่มี ?v= cache-bust)
# Phase 33 fix: เดิมใช้ immutable 1 ปี → main.js?v=N โหลดใหม่ แต่ /modules/*.js stale
# → user เห็น version display เก่า แม้ main.js ใหม่ — แก้ด้วย must-revalidate (ETag check)
/modules/*
  Cache-Control: public, max-age=0, must-revalidate

# Icons / images: cache 7 วัน
/icons/*
  Cache-Control: public, max-age=604800

# AI chat widget — must-revalidate (เหตุผลเดียวกับ /modules/*)
/ai-chat-widget.js
  Cache-Control: public, max-age=0, must-revalidate

# Phase 41 — Cache Drift cleanup (pre-emptive audit)
# Phase 4 design system + Print stylesheet — must-revalidate (ป้องกัน UI พังเหมือน Phase 38 logo overflow)
/phase4-design-system.css
  Cache-Control: public, max-age=0, must-revalidate
/phase4-components.css
  Cache-Control: public, max-age=0, must-revalidate
/doc-print.css
  Cache-Control: public, max-age=0, must-revalidate

# Supabase config — CRITICAL: ถ้า URL/anonKey เปลี่ยน user เก่าจะ connect ไม่ได้
# no-cache บังคับ revalidate ทุกครั้ง
/supabase-config.js
  Cache-Control: no-cache, must-revalidate
